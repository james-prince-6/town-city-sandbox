QuestSystem="*res://global/systems/quest_system.gd"
Progression="*res://global/systems/progression.gd"
NPCMoods="*res://global/npc/npc_moods.gd"
CraftingSystem="*res://global/systems/crafting_system.gd"
HUD="*res://ui/hud/hud.tscn"
QuestLog="*res://ui/quest_log/quest_log.tscn"
