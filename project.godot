SaveManager="*res://global/systems/save_manager.gd"
ShopSystem="*res://global/systems/shop_system.gd"
ShopUI="*res://ui/shop/shop_ui.tscn"
PauseMenu="*res://ui/pause/pause_menu.gd"
DeathScreen="*res://ui/death/death_screen.gd"
MinigameManager="*res://global/minigames/minigame_manager.gd"
SkillTreeUI="*res://ui/progression/skill_tree_ui.tscn"
CombatFeel="*res://global/combat/combat_feel.gd"
UISound="*res://global/ui/ui_sound.gd"
MenuManager="*res://global/ui/menu_manager.gd"
CraftingUI="*res://ui/crafting/crafting_ui.tscn"
PlayerMenu="*res://ui/player_menu/player_menu.tscn"
MainMenu="*res://ui/main_menu/main_menu.gd"
SaveSlotMenu="*res://ui/save_menu/save_slot_menu.gd"
NotificationFeed="*res://ui/notifications/notification_feed.gd"
AmbientAudio="*res://global/systems/ambient_audio.gd"

[dialogue_manager]

runtime/balloon_path="res://ui/dialog/dialogue_balloon.tscn"

[editor_plugins]

enabled=PackedStringArray("res://addons/MarchingSquaresTerrain/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg")

