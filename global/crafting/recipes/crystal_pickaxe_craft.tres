[gd_resource type="Resource" script_class="Recipe" load_steps=5 format=3]

[ext_resource type="Script" path="res://global/crafting/recipe.gd" id="1_recipe"]
[ext_resource type="Script" path="res://global/crafting/recipe_ingredient.gd" id="2_ingredient"]

[sub_resource type="Resource" id="ing_crystal"]
script = ExtResource("2_ingredient")
item_id = &"polished_crystal"
count = 3

[sub_resource type="Resource" id="ing_gold"]
script = ExtResource("2_ingredient")
item_id = &"gold_ingot"
count = 2

[resource]
script = ExtResource("1_recipe")
id = &"crystal_pickaxe_craft"
display_name = "Crystal Pickaxe"
inputs = [SubResource("ing_crystal"), SubResource("ing_gold")]
output_id = &"crystal_pickaxe"
output_count = 1
brew_minutes = 0
instant = true
machine_type = 2
