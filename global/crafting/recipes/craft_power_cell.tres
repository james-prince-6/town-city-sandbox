[gd_resource type="Resource" script_class="Recipe" load_steps=5 format=3]

[ext_resource type="Script" path="res://global/crafting/recipe.gd" id="1_recipe"]
[ext_resource type="Script" path="res://global/crafting/recipe_ingredient.gd" id="2_ingredient"]

[sub_resource type="Resource" id="ing_core"]
script = ExtResource("2_ingredient")
item_id = &"power_core"
count = 1

[sub_resource type="Resource" id="ing_metal"]
script = ExtResource("2_ingredient")
item_id = &"refined_metal"
count = 1

[resource]
script = ExtResource("1_recipe")
id = &"craft_power_cell"
display_name = "Power Cell"
inputs = [SubResource("ing_core"), SubResource("ing_metal")]
output_id = &"power_cell"
output_count = 1
brew_minutes = 0
instant = true
machine_type = 2
