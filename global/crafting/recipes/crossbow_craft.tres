[gd_resource type="Resource" script_class="Recipe" load_steps=5 format=3]

; Crossbow — crafted at a Workbench from refined copper + fibre.
[ext_resource type="Script" path="res://global/crafting/recipe.gd" id="1_recipe"]
[ext_resource type="Script" path="res://global/crafting/recipe_ingredient.gd" id="2_ingredient"]

[sub_resource type="Resource" id="ing_ingot"]
script = ExtResource("2_ingredient")
item_id = &"copper_ingot"
count = 3

[sub_resource type="Resource" id="ing_fiber"]
script = ExtResource("2_ingredient")
item_id = &"plant_fiber"
count = 2

[resource]
script = ExtResource("1_recipe")
id = &"crossbow_craft"
display_name = "Crossbow"
inputs = [SubResource("ing_ingot"), SubResource("ing_fiber")]
output_id = &"crossbow"
output_count = 1
brew_minutes = 0
instant = true
machine_type = 2
