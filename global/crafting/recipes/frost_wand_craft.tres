[gd_resource type="Resource" script_class="Recipe" load_steps=5 format=3]

; Frost Wand — crafted at a Workbench. Needs sulfur crystals (dungeon drops / shop).
[ext_resource type="Script" path="res://global/crafting/recipe.gd" id="1_recipe"]
[ext_resource type="Script" path="res://global/crafting/recipe_ingredient.gd" id="2_ingredient"]

[sub_resource type="Resource" id="ing_vial"]
script = ExtResource("2_ingredient")
item_id = &"lava_vial"
count = 2

[sub_resource type="Resource" id="ing_sulfur"]
script = ExtResource("2_ingredient")
item_id = &"sulfur_crystal"
count = 3

[resource]
script = ExtResource("1_recipe")
id = &"frost_wand_craft"
display_name = "Frost Wand"
inputs = [SubResource("ing_vial"), SubResource("ing_sulfur")]
output_id = &"frost_wand"
output_count = 1
brew_minutes = 0
instant = true
machine_type = 2
