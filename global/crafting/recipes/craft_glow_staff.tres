[gd_resource type="Resource" script_class="Recipe" load_steps=6 format=3]

[ext_resource type="Script" path="res://global/crafting/recipe.gd" id="1_recipe"]
[ext_resource type="Script" path="res://global/crafting/recipe_ingredient.gd" id="2_ingredient"]

[sub_resource type="Resource" id="ing_glow"]
script = ExtResource("2_ingredient")
item_id = &"glow_crystal"
count = 1

[sub_resource type="Resource" id="ing_cell"]
script = ExtResource("2_ingredient")
item_id = &"power_cell"
count = 1

[sub_resource type="Resource" id="ing_obsidian"]
script = ExtResource("2_ingredient")
item_id = &"obsidian"
count = 1

[resource]
script = ExtResource("1_recipe")
id = &"craft_glow_staff"
display_name = "Glow Staff"
inputs = [SubResource("ing_glow"), SubResource("ing_cell"), SubResource("ing_obsidian")]
output_id = &"glow_staff"
output_count = 1
brew_minutes = 0
instant = true
machine_type = 2
