[gd_resource type="Resource" script_class="Skill" load_steps=2 format=3]

; SURVIVAL end-game perk: scales with PLAYER LEVEL, not rank. Progression.melee_damage_mult() and
; ranged_damage_mult() add LATE_BLOOMER_DMG_PER_LEVEL per level above ENDGAME_SCALE_LEVEL once this
; is owned (get_rank > 0). Carries no stat_per_rank — the bonus is computed from level in code, so
; it keeps growing into the late game where flat skill passives have already hard-capped.

[ext_resource type="Script" path="res://global/progression/skill.gd" id="1_skill"]

[resource]
script = ExtResource("1_skill")
id = &"late_bloomer"
display_name = "Late Bloomer"
description = "Your mastery never stops sharpening. +3% weapon damage for every level you earn past 10."
branch = 2
max_rank = 1
cost = 2
required_level = 10
prerequisite = &"toughness"
prerequisite_rank = 4
is_perk = true
stat_per_rank = {}
