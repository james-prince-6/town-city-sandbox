[gd_resource type="Resource" script_class="Skill" load_steps=2 format=3]

; SURVIVAL passive: flat percentage damage reduction. The player's _on_hurt scales incoming
; damage by (1.0 - Progression.damage_reduction()), summed from the &"damage_reduction"
; stat key and capped at 90%. A scaling defensive line off Toughness.

[ext_resource type="Script" path="res://global/progression/skill.gd" id="1_skill"]

[resource]
script = ExtResource("1_skill")
id = &"thick_skin"
display_name = "Thick Skin"
description = "Calloused and battle-worn. Take 6% less damage from all sources per rank."
branch = 2
max_rank = 3
cost = 1
required_level = 3
prerequisite = &"toughness"
prerequisite_rank = 2
is_perk = false
stat_per_rank = {
&"damage_reduction": 0.06
}
