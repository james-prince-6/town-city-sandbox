[gd_resource type="Resource" script_class="Quest" load_steps=7 format=3]

[ext_resource type="Script" path="res://global/quests/quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://global/quests/quest_objective.gd" id="2_objective"]
[ext_resource type="Script" path="res://global/quests/game_effect.gd" id="3_effect"]

[sub_resource type="Resource" id="Resource_objective_ore"]
script = ExtResource("2_objective")
description = "Bring Marlo 2 iron ore"
kind = 0
target = &"iron_ore"
required_count = 2

[sub_resource type="Resource" id="Resource_reward_money"]
script = ExtResource("3_effect")
type = 5
target = &""
amount = 50

[sub_resource type="Resource" id="Resource_reward_rep"]
script = ExtResource("3_effect")
type = 4
target = &"marlo"
amount = 10

[resource]
script = ExtResource("1_quest")
id = &"marlo_first_delivery"
title = "Marlo's First Delivery"
description = "Marlo needs iron ore for the brewery's new fittings. Round up a couple of lumps and bring them back."
objectives = Array[ExtResource("2_objective")]([SubResource("Resource_objective_ore")])
rewards = Array[ExtResource("3_effect")]([SubResource("Resource_reward_money"), SubResource("Resource_reward_rep")])
