[gd_resource type="Resource" script_class="Quest" load_steps=7 format=3]

[ext_resource type="Script" path="res://global/quests/quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://global/quests/quest_objective.gd" id="2_objective"]
[ext_resource type="Script" path="res://global/quests/game_effect.gd" id="3_effect"]

[sub_resource type="Resource" id="obj"]
script = ExtResource("2_objective")
description = "Bring Pip 2 coconuts for his stash"
kind = 0
target = &"coconut"
required_count = 2

[sub_resource type="Resource" id="reward_money"]
script = ExtResource("3_effect")
type = 5
target = &""
amount = 60

[sub_resource type="Resource" id="reward_rep"]
script = ExtResource("3_effect")
type = 4
target = &"pip"
amount = 10

[resource]
script = ExtResource("1_quest")
id = &"task_pip_cache"
title = "Wanderer's Cache"
description = "Pip likes to bury little stashes around the island. Fetch him 2 coconuts for his next hidey-hole before he forgets where this one is."
tier = 2
objectives = Array[ExtResource("2_objective")]([SubResource("obj")])
rewards = Array[ExtResource("3_effect")]([SubResource("reward_money"), SubResource("reward_rep")])
time_limit_minutes = 360
giver_npc_id = &"pip"
repeatable = true
cooldown_minutes = 600
