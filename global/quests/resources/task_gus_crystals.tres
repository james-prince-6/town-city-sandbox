[gd_resource type="Resource" script_class="Quest" load_steps=8 format=3]

[ext_resource type="Script" path="res://global/quests/quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://global/quests/quest_objective.gd" id="2_objective"]
[ext_resource type="Script" path="res://global/quests/game_effect.gd" id="3_effect"]

[sub_resource type="Resource" id="obj"]
script = ExtResource("2_objective")
description = "Bring 2 glow crystals to brighten Gus's store"
kind = 0
target = &"glow_crystal"
required_count = 2

[sub_resource type="Resource" id="reward_money"]
script = ExtResource("3_effect")
type = 5
target = &""
amount = 110

[sub_resource type="Resource" id="reward_rep"]
script = ExtResource("3_effect")
type = 4
target = &"gus"
amount = 14

[sub_resource type="Resource" id="take_glow"]
script = ExtResource("3_effect")
type = 3
target = &"glow_crystal"
amount = 2

[resource]
script = ExtResource("1_quest")
id = &"task_gus_crystals"
title = "Restock: Glow Crystals"
description = "Gus wants to light his shelves with something that won't gutter. Bring him 2 glow crystals from below before a customer trips in the gloom."
tier = 2
objectives = Array[ExtResource("2_objective")]([SubResource("obj")])
rewards = Array[ExtResource("3_effect")]([SubResource("reward_money"), SubResource("reward_rep"), SubResource("take_glow")])
time_limit_minutes = 600
giver_npc_id = &"gus"
repeatable = true
cooldown_minutes = 600
