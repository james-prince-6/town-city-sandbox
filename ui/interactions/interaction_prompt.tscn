[gd_scene load_steps=2 format=3 uid="uid://pawwtidw1byp"]

[ext_resource type="Script" uid="uid://d3h8ehowk0d6p" path="res://ui/interactions/interaction_prompt.gd" id="1_ewwgb"]

[node name="InteractionPrompt" type="CanvasLayer"]
script = ExtResource("1_ewwgb")

; Anchored to the BOTTOM-RIGHT corner. The PanelContainer auto-sizes to its
; contents and grows up/left from the corner, so a multi-line action list stacks
; upward. The 16px offsets keep it off the screen edge.
[node name="PanelContainer" type="PanelContainer" parent="."]
anchors_preset = 3
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -160.0
offset_top = -56.0
offset_right = -16.0
offset_bottom = -16.0
grow_horizontal = 0
grow_vertical = 0

[node name="Margin" type="MarginContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 6

; One Label per available action is created here at runtime by the script.
[node name="Lines" type="VBoxContainer" parent="PanelContainer/Margin"]
layout_mode = 2
theme_override_constants/separation = 4
