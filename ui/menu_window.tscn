[gd_scene load_steps=3 format=3 uid="uid://towncity_menu_window"]

; =============================================================
;  Town City — reusable centered Window shell.
;  Instance this for any full-screen menu: an ink-wash backdrop
;  (blocks world clicks) + a centered cream Window with a title
;  row, an empty %Body container you fill, and an empty %Footer
;  button row. Set %Title text and populate %Body / %Footer.
; =============================================================

[ext_resource type="Theme" path="res://ui/town_city_theme.tres" id="1_theme"]

[node name="MenuWindow" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("1_theme")

; ink wash — STOP so the paused world doesn't receive clicks
[node name="Backdrop" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 1
color = Color(0.055, 0.051, 0.071, 0.55)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Window" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(480, 300)
layout_mode = 2
theme_type_variation = &"MenuWindow"

[node name="VBox" type="VBoxContainer" parent="Center/Window"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="TitleRow" type="HBoxContainer" parent="Center/Window/VBox"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Center/Window/VBox/TitleRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"Title"
text = "Menu"

[node name="Close" type="Button" parent="Center/Window/VBox/TitleRow"]
unique_name_in_owner = true
layout_mode = 2
focus_mode = 2
text = "Esc"

[node name="Body" type="VBoxContainer" parent="Center/Window/VBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 10

[node name="Footer" type="HBoxContainer" parent="Center/Window/VBox"]
unique_name_in_owner = true
layout_mode = 2
alignment = 2
theme_override_constants/separation = 8
