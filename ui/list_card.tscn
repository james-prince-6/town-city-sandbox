[gd_scene load_steps=2 format=3 uid="uid://towncity_list_card"]

; =============================================================
;  Town City — reusable list Card row.
;  The repeating entry for shop/craft/quest/upgrade lists.
;  Set %Title, %Detail (dim sub-line), and %Action (the Buy /
;  Craft / Track button). For gated content, swap the root's
;  theme_type_variation to &"CardLocked" and disable %Action.
; =============================================================

[ext_resource type="Theme" path="res://ui/town_city_theme.tres" id="1_theme"]

[node name="ListCard" type="PanelContainer"]
theme = ExtResource("1_theme")
theme_type_variation = &"Card"

[node name="HBox" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Text" type="VBoxContainer" parent="HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="Title" type="Label" parent="HBox/Text"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"Subtitle"
text = "Item Name"

[node name="Detail" type="Label" parent="HBox/Text"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"Dim"
text = "detail line"

[node name="Action" type="Button" parent="HBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 4
focus_mode = 2
text = "Buy"
