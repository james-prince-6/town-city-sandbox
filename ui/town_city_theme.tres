[resource]
default_font = SubResource("font_body")
default_font_size = 15

; base Label = Space Grotesk, ink text
Label/fonts/font = SubResource("font_body")
Label/font_sizes/font_size = 15
Label/colors/font_color = Color(0.133, 0.122, 0.102, 1)

PanelContainer/styles/panel = SubResource("sb_panel")
Panel/styles/panel = SubResource("sb_panel")

; ProgressBar base (background = track, fill set per-variation below)
ProgressBar/styles/background = SubResource("sb_track")
ProgressBar/styles/fill = SubResource("sb_fill_hp")

; scrollbars (cream sticker)
HScrollBar/styles/scroll = SubResource("sb_scroll")
HScrollBar/styles/grabber = SubResource("sb_grabber")
HScrollBar/styles/grabber_highlight = SubResource("sb_grabber_hl")
HScrollBar/styles/grabber_pressed = SubResource("sb_grabber_hl")
VScrollBar/styles/scroll = SubResource("sb_scroll")
VScrollBar/styles/grabber = SubResource("sb_grabber")
VScrollBar/styles/grabber_highlight = SubResource("sb_grabber_hl")
VScrollBar/styles/grabber_pressed = SubResource("sb_grabber_hl")

