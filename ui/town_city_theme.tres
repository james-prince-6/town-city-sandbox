; =============================================================
;  Town City — JSR UI Theme  (locked palette: HUD + menu kit)
;  Flat sticker style: cream panels, ink outlines, NO shadows.
;  Color is reserved — health red, stamina green, mana purple,
;  sun + quest/level titles gold. Everything else cream / ink.
;
;  FONTS:
;    Chakra Petch SemiBold  -> display (clock, money, titles, hotbar)
;    Space Grotesk Bold     -> readout / body   (variable TTF; pinned
;                              to weight 700 via the font_body variation)
;
;  Built from the design package, with three local fixes:
;   - font_body FontVariation pins Space Grotesk to wght 700 (the raw
;     variable TTF imports at a light default and looked thin).
;   - the gold quest-tab stylebox is sb_qtab (the design reused the id
;     "sb_tab" for two different boxes — a collision).
;   - hotbar ink frame thickened + selected cell gets a gold outline
;     (per playtest feedback).
; =============================================================
[gd_resource type="Theme" load_steps=34 format=3]

[ext_resource type="FontFile" path="res://ui/fonts/ChakraPetch-SemiBold.ttf" id="1_chakra"]
[ext_resource type="FontFile" path="res://ui/fonts/SpaceGrotesk-Bold.ttf" id="2_space"]

; Space Grotesk ships as a VARIABLE font; pin it to weight 700 (Bold) so body text
; reads with the intended heft. 2003265652 is the 'wght' OpenType tag as a 32-bit int.
[sub_resource type="FontVariation" id="font_body"]
base_font = ExtResource("2_space")
variation_opentype = {
2003265652: 700.0
}

; ---- cream panel, 3px ink border, radius 5, no shadow ----
[sub_resource type="StyleBoxFlat" id="sb_panel"]
bg_color = Color(0.906, 0.882, 0.831, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.055, 0.051, 0.071, 1)
corner_radius_top_left = 5
corner_radius_top_right = 5
corner_radius_bottom_right = 5
corner_radius_bottom_left = 5
content_margin_left = 12.0
content_margin_top = 6.0
content_margin_right = 12.0
content_margin_bottom = 6.0

