[gd_scene load_steps=5 format=3 uid="uid://crepc2svamqom"]

; =============================================================
;  Town City — HUD  (Town City sticker design language)
;  Autoload (HUD -> this scene). Pure view: mirrors PlayerStats,
;  GameState, Clock, Hotbar, Inventory. Top-left = info strip +
;  three stat bars; bottom-centre = unified hotbar; centre dot.
;  Hotbar cells are built in code (hud.gd) so SLOT_COUNT can vary.
; =============================================================

[ext_resource type="Script" uid="uid://3y2h481n1aue" path="res://ui/hud/hud.gd" id="1_hud"]

[sub_resource type="Shader" id="Shader_vignette"]
code = "// Cheap radial vignette: tints only the screen EDGES, leaving the centre
// clear. `intensity` (0..1) is driven from hud.gd as a stat drops low.
shader_type canvas_item;

uniform float intensity : hint_range(0.0, 1.0) = 0.0;
uniform vec4 tint : source_color = vec4(0.7, 0.0, 0.0, 1.0);

void fragment() {
	float d = distance(UV, vec2(0.5));
	float edge = smoothstep(0.25, 0.75, d);
	COLOR = vec4(tint.rgb, edge * intensity);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vignette"]
shader = SubResource("Shader_vignette")
shader_parameter/intensity = 0.0
shader_parameter/tint = Color(0.7, 0, 0, 1)

[sub_resource type="ShaderMaterial" id="ShaderMaterial_stamina"]
shader = SubResource("Shader_vignette")
shader_parameter/intensity = 0.0
shader_parameter/tint = Color(1.0, 0.6, 0.05, 1)

[node name="HUD" type="CanvasLayer"]
layer = 5
script = ExtResource("1_hud")

; ===================== TOP-LEFT STACK =====================
[node name="TopLeft" type="VBoxContainer" parent="."]
custom_minimum_size = Vector2(212, 0)
offset_left = 22.0
offset_top = 20.0
offset_right = 234.0
offset_bottom = 220.0
mouse_filter = 2
theme_override_constants/separation = 5

