[sub_resource type="Shader" id="Shader_vignette"]
code = "// Cheap radial vignette: tints only the screen EDGES red, leaving the centre
// clear. `intensity` (0..1) is driven from hud.gd as health drops below 25%.
shader_type canvas_item;

uniform float intensity : hint_range(0.0, 1.0) = 0.0;
uniform vec4 tint : source_color = vec4(0.7, 0.0, 0.0, 1.0);

void fragment() {
	// Distance from screen centre, 0 at middle -> ~0.7 at the corners.
	float d = distance(UV, vec2(0.5));
	// Ramp that stays clear in the middle and rises toward the edges.
	float edge = smoothstep(0.25, 0.75, d);
	COLOR = vec4(tint.rgb, edge * intensity);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vignette"]
