; guild_mine.tscn
; The Adventurers Guild's Mine: an inherited variant of generated_dungeon.tscn that only
; overrides where its EXIT portal leads — back to the Guild (spawn "from_town") instead of
; the shared default (Town). Geometry/enemies/loot are still generated by dungeon_generator.gd;
; a distinct start_seed gives it its own layout. Repointed from adventurers_guild.gd's DUNGEON.
[gd_scene load_steps=2 format=3 uid="uid://guildmineproc01"]

[ext_resource type="PackedScene" uid="uid://cgendungproc01" path="res://stages/dungeons/procedural/generated_dungeon.tscn" id="1_base"]

[node name="GeneratedDungeon" instance=ExtResource("1_base")]
start_seed = 49157
exit_scene_path = "res://stages/interiors/adventurers_guild.tscn"
exit_spawn_point = &"from_town"
