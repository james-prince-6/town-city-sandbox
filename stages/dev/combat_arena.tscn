transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 14)

; Enemies are staged in a line ahead of the player (who faces -Z) and spaced so they
; engage in sequence rather than all swarming at once: only the nearest Husk is inside
; its detect range at spawn; advancing wakes the next, then the Spitter, then the Brute.
; All four sit within the forward view so they're visible, not lost in the distance.
[node name="EmberHound1" parent="." instance=ExtResource("2_hound")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 4)

